# NewsAPI key for the Outbreak Intelligence Feed. Obtain a free key at https://newsapi.org.
# Without this key, the /api/news endpoint falls back to synthetic headlines automatically.
NEWS_API_KEY=your_newsapi_key_here

# Application environment. Set to "production" when deploying outside localhost.
APP_ENV=development

# Host and port for uvicorn. Defaults are safe for local development.
APP_HOST=127.0.0.1
APP_PORT=8000
